# Paste these into Vercel → walkchamp-backend → Settings → Environment Variables
# Copy VALUES from your Replit project → Tools → Secrets (same names unless noted).
# Enable for: Production, Preview, Development
#
# After saving, redeploy from latest main.

# ── REQUIRED ─────────────────────────────────────────────────────────────────
NEON_DATABASE_URL=
DESCOPE_PROJECT_ID=
SESSION_SECRET=
NODE_ENV=production

# ── Production URLs ──────────────────────────────────────────────────────────
# Was REPLIT_DOMAINS on Replit — use your Vercel API URL:
APP_BASE_URL=https://walkchamp-backend-sooty.vercel.app
# Your Expo web / production app origins (comma-separated):
ALLOWED_ORIGINS=https://walkchamp.app

# ── Auth ───────────────────────────────────────────────────────────────────────
DESCOPE_MANAGEMENT_KEY=

# ── Real-time ──────────────────────────────────────────────────────────────────
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=

# ── Push ───────────────────────────────────────────────────────────────────────
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

# ── Payments (test mode — set matching secret in Vercel only, never commit) ───
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=rzp_test_T2jKlttzxL1WzR
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Voice ──────────────────────────────────────────────────────────────────────
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── Storage (OCI) ──────────────────────────────────────────────────────────────
OCI_NAMESPACE=
OCI_REGION=
OCI_BUCKET_NAME=
OCI_ACCESS_KEY_ID=
OCI_SECRET_ACCESS_KEY=

# ── Admin ──────────────────────────────────────────────────────────────────────
ADMIN_API_KEY=

# ── Optional ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
