# Walk Champ — Backend environment variables
# Copy to .env and fill in your values.

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
LOG_LEVEL=info
APP_PROCESS_ROLE=api

# Public API base URL (used for payment redirects and webhooks)
APP_BASE_URL=http://localhost:8080

# Comma-separated exact CORS origins (required in production)
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:3000
TRUST_PROXY_HOPS=1

# Set to false on all but one replica when running multiple backend instances.
RUN_BACKGROUND_JOBS=true
ENABLE_RATE_LIMITING=false
REDIS_URL=
MOCK_PROVIDERS_ENABLED=false
ALLOW_TEST_ROUTES=false
ALLOW_DEMO_SEEDS=false

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_RUNTIME_URL=
DATABASE_ADMIN_URL=
NEON_DATABASE_URL=
NEON_DATABASE_ADMIN_URL=
# Alternative name (falls back if NEON_DATABASE_URL is unset)
DATABASE_URL=

# ── Auth (Descope) ─────────────────────────────────────────────────────────────
DESCOPE_PROJECT_ID=
DESCOPE_MANAGEMENT_KEY=
SESSION_SECRET=
APPLE_EXPECTED_AUDIENCES=com.globalwalkerleague.app

# ── Real-time (Pusher) ─────────────────────────────────────────────────────────
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=

# ── Push notifications (OneSignal) ────────────────────────────────────────────
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

# ── Payments ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Additional per-player platform fee for cash challenges, in cents.
CASH_CHALLENGE_PLATFORM_SERVICE_FEE_CENTS=60
# Both must be "true" for paid cash challenges ($3/$5/etc.) to work.
CASH_FEATURES_ENABLED=false

# ── Voice (LiveKit) ────────────────────────────────────────────────────────────
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── Object storage (Cloudflare R2 / S3-compatible) ────────────────────────────
OBJECT_STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_PUBLIC_BASE_URL=https://assets.example.com
BACKUP_OBJECT_PREFIX=backups/production

# ── Monitoring ─────────────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ── Admin ──────────────────────────────────────────────────────────────────────
ADMIN_API_KEY=
ADMIN_SERVICE_KEY=
ADMIN_USER_IDS=

# ── Feature flags (env overrides) ──────────────────────────────────────────────
# Both must be "true" for paid cash challenges ($3/$5/etc.) to work.
FEATURE_CASH_FEATURES=false
FEATURE_COIN_ENTRY_CHALLENGES=false
FEATURE_LEGACY_PRESENCE_ONLINE_IDS=false
