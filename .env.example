# Walk Champ — Backend environment variables
# Copy to .env locally, or paste into Vercel → Settings → Environment Variables.
#
# ── Replit → new name mapping ─────────────────────────────────────────────────
# Replit secret              → Use this name now
# NEON_DATABASE_URL          → NEON_DATABASE_URL  (or DATABASE_URL)
# DESCOPE_PROJECT_ID         → DESCOPE_PROJECT_ID
# DESCOPE_MANAGEMENT_KEY     → DESCOPE_MANAGEMENT_KEY
# SESSION_SECRET             → SESSION_SECRET
# REPLIT_DOMAINS             → APP_BASE_URL  (e.g. https://walkchamp-backend-sooty.vercel.app)
# PUSHER_APP_ID/KEY/SECRET   → same names (backend)
# PUSHER_CLUSTER             → PUSHER_CLUSTER
# STRIPE_SECRET_KEY          → STRIPE_SECRET_KEY
# STRIPE_WEBHOOK_SECRET      → STRIPE_WEBHOOK_SECRET
# RAZORPAY_KEY_ID/SECRET     → RAZORPAY_KEY_ID, RAZORPAY_KEY_SECRET
# RAZORPAY_WEBHOOK_SECRET    → RAZORPAY_WEBHOOK_SECRET
# ONESIGNAL_APP_ID           → ONESIGNAL_APP_ID
# ONESIGNAL_REST_API_KEY     → ONESIGNAL_REST_API_KEY
# OCI_*                      → same names (avatar storage)
# LIVEKIT_URL/API_KEY/SECRET → same names (voice chat)
# ADMIN_API_KEY              → ADMIN_API_KEY
#
# On Vercel, VERCEL_URL is set automatically. APP_BASE_URL is optional if you use the Vercel URL.

# ── REQUIRED (app will not start without these) ───────────────────────────────
NEON_DATABASE_URL=
# Alternative name (same value as Neon pooled connection string)
DATABASE_URL=

DESCOPE_PROJECT_ID=
SESSION_SECRET=

# ── Server (required for production) ──────────────────────────────────────────
NODE_ENV=production
PORT=8080
LOG_LEVEL=info

# Public API URL — payment redirects & webhooks (was REPLIT_DOMAINS on Replit)
APP_BASE_URL=https://walkchamp-backend-sooty.vercel.app

# Comma-separated frontend origins allowed by CORS
ALLOWED_ORIGINS=https://walkchamp.app,http://localhost:8081

# ── Auth (Descope) — management key required for password reset / OAuth ───────
DESCOPE_MANAGEMENT_KEY=

# ── Real-time (Pusher) — backend only; frontend uses EXPO_PUBLIC_PUSHER_KEY ─
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=

# ── Push notifications (OneSignal) — backend REST API ─────────────────────────
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

# ── Payments ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Voice (LiveKit) ──────────────────────────────────────────────────────────
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── Object storage (OCI S3-compatible) — avatars / group images ─────────────
# From bucket Details page: Namespace + bucket name + region (NOT the bucket OCID).
OCI_NAMESPACE=axadzcltpbiu
OCI_REGION=us-chicago-1
OCI_BUCKET_NAME=walkchamp
# From Profile → User settings → Customer secret keys (S3-compatible API):
#   Access Key  → OCI_ACCESS_KEY_ID   (shown in the keys table — NOT bucket OCID)
#   Secret Key  → OCI_SECRET_ACCESS_KEY (shown only once when the key is created)
OCI_ACCESS_KEY_ID=
OCI_SECRET_ACCESS_KEY=

# ── Admin ──────────────────────────────────────────────────────────────────────
ADMIN_API_KEY=
