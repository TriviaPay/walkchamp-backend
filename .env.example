# Walk Champ — Backend environment variables
# Copy to .env and fill in your values.

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# Public API base URL (used for payment redirects and webhooks)
APP_BASE_URL=http://localhost:8080

# Comma-separated CORS origin prefixes (required in production)
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:3000

# ── Database ───────────────────────────────────────────────────────────────────
NEON_DATABASE_URL=
# Alternative name (falls back if NEON_DATABASE_URL is unset)
DATABASE_URL=

# ── Auth (Descope) ─────────────────────────────────────────────────────────────
DESCOPE_PROJECT_ID=
DESCOPE_MANAGEMENT_KEY=
SESSION_SECRET=

# ── Real-time (Pusher) ─────────────────────────────────────────────────────────
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=

# ── Push notifications (OneSignal) ────────────────────────────────────────────
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

# ── Payments ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Voice (LiveKit) ────────────────────────────────────────────────────────────
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── Object storage (OCI S3-compatible) ────────────────────────────────────────
OCI_NAMESPACE=
OCI_REGION=
OCI_BUCKET_NAME=
OCI_ACCESS_KEY_ID=
OCI_SECRET_ACCESS_KEY=

# ── Admin ──────────────────────────────────────────────────────────────────────
ADMIN_API_KEY=
