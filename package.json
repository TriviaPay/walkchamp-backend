{
  "name": "walkchamp-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.15.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "ci:verify": "pnpm run typecheck && pnpm run test && pnpm run build",
    "vercel-build": "pnpm run build",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "worker": "node --enable-source-maps ./dist/worker.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:integration": "node ./build.mjs && vitest run ./src/__tests__/integration-http.test.ts",
    "test:load": "node ./build.mjs && tsx ./scripts/src/loadSmoke.ts",
    "db:generate": "drizzle-kit generate --config ./db/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config ./db/drizzle.config.ts",
    "db:adopt-existing": "tsx ./scripts/src/adoptExistingDb.ts",
    "storage:rewrite-urls": "tsx ./scripts/src/rewriteObjectStorageUrls.ts",
    "seed:achievements": "tsx ./scripts/src/seedAchievements.ts",
    "create:today-events": "tsx ./scripts/src/createTodayEvents.ts",
    "check:sponsored-races": "tsx ./scripts/src/checkSponsoredRaces.ts",
    "create:evening-events": "tsx ./scripts/src/createEveningEvents.ts",
    "seed:test-titles": "tsx ./scripts/src/seedTestTitles.ts",
    "apply-db-indexes": "tsx ./scripts/src/apply-db-indexes.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "@descope/node-sdk": "^2.6.0",
    "@sentry/node": "^9.46.0",
    "@types/compression": "^1.8.1",
    "@types/multer": "^2.1.0",
    "bullmq": "^5.58.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "livekit-server-sdk": "^2.15.4",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.10",
    "pg": "^8.20.0",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "pusher": "^5.3.3",
    "razorpay": "^2.9.6",
    "resend": "^6.12.4",
    "ioredis": "^5.8.2",
    "stripe": "^22.1.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "esbuild": "0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "orval": "^8.9.1",
    "pino-pretty": "^13.1.3",
    "thread-stream": "3.1.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "vitest": "^4.1.8"
  }
}
